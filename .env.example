# Copy to .env and fill in your keys.

# OpenRouter — used for 4 models (gpt-4o-mini, glm-4.7-flash,
# deepseek-r1-distill-qwen-32b, minimax-m2.5).
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# LM Studio — local server for 2 medical models (medgemma-27b, openbiollm-8b).
# LM Studio does not validate the key, any non-empty string works.
LMSTUDIO_API_KEY=lm-studio

# HuggingFace — only needed if downloading gated MedQA variants.
# The default bigbio/med_qa dataset is open, so this is usually optional.
HF_TOKEN=
